{
  "name": "juice",
  "version": "12.1.1",
  "description": "Inlines css into html source",
  "type": "module",
  "bin": "bin/juice",
  "main": "index.js",
  "browser": "client.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./client.js",
      "default": "./index.js"
    },
    "./client": "./client.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "lib",
    "client.js",
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "test": "vitest run --coverage && npm run test-typescript",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test-typescript": "tsc -p test/typescript && rm ./test/typescript/juice-tests.js"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "Guillermo Rauch"
    },
    {
      "name": "Andrew Kelley"
    },
    {
      "name": "Jarrett Widman"
    },
    {
      "name": "Cosmin Popovici"
    }
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "commander": "^14.0.3",
    "entities": "^8.0.0",
    "postcss": "^8.5.0",
    "postcss-nesting": "^14.0.0",
    "postcss-safe-parser": "^7.0.1",
    "postcss-selector-parser": "^7.1.0",
    "web-resource-inliner": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-spawn": "^7.0.3",
    "typescript": "^5.5.4",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Automattic/juice.git"
  }
}
